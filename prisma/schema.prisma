// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Slidy : persistance utilisateurs, présentations, documents IA, médias, jobs de génération.
// La génération (Groq) ne passe pas par PostgreSQL.

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DATABASE_URL")

}


enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum PlanTier {
  STARTER
  PRO
  ULTIMATE
}

enum DocumentType {
  PRESENTATION
  WHITEBOARD
  DOCUMENT
  NOTES
  VISUAL_PAGE
  MARKETING_PRESENTATION
  CV_COVER
}

enum DocumentStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum BlockType {
  TITLE
  HEADING
  TEXT
  BULLETS
  IMAGE
  CHART
  QUOTE
  CTA
  DIVIDER
}

enum ImageSource {
  AI
  STOCK
  UPLOAD
}

enum GenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  hashedPassword     String?
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accounts          Account[]
  sessions          Session[]
  presentations     Presentation[]
  documents         AiDocument[]
  generationJobs    GenerationJob[]
  mediaAssets       MediaAsset[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Template {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  category       String?
  planTier       PlanTier @default(STARTER)
  colorPrimary   String?
  colorSecondary String?
  colorAccent    String?
  colorBg        String?
  colorText      String?
  fontHeading    String?
  fontBody       String?
  previewImage   String?
  isFeatured     Boolean  @default(false)

  @@map("templates")
}

model Presentation {
  id               String   @id @default(cuid())
  userId           String
  title            String
  topic            String
  audience         String
  presentationType String
  templateSlug     String
  slideCount       Int
  slidesJson       String
  fileUrl          String?
  isPublic         Boolean  @default(false)
  status           String   @default("generating")
  options          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presentations")
  @@index([userId, createdAt])
}

model AiDocument {
  id            String         @id @default(cuid())
  userId        String
  title         String
  topic         String
  type          DocumentType   @default(PRESENTATION)
  audience      String?
  detailLevel   String?
  templateSlug  String?
  designOptions Json?
  status        DocumentStatus @default(DRAFT)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks         DocumentBlock[]
  generationJobs GenerationJob[]

  @@map("ai_documents")
  @@index([userId, type, createdAt])
  @@index([status])
}

model DocumentBlock {
  id          String    @id @default(cuid())
  documentId  String
  blockType   BlockType
  position    Int
  contentJson Json
  styleJson   Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document AiDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_blocks")
  @@unique([documentId, position])
  @@index([documentId])
}

model MediaAsset {
  id           String      @id @default(cuid())
  userId       String
  source       ImageSource
  title        String?
  altText      String?
  mimeType     String?
  width        Int?
  height       Int?
  storageUrl   String
  thumbnailUrl String?
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("media_assets")
  @@index([userId, source, createdAt])
}

model GenerationJob {
  id            String           @id @default(cuid())
  userId        String
  documentId    String?
  status        GenerationStatus @default(QUEUED)
  prompt        String
  model         String?
  detailLevel   String?
  requestedType DocumentType     @default(PRESENTATION)
  optionsJson   Json?
  resultJson    Json?
  errorMessage  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  document AiDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@map("generation_jobs")
  @@index([userId, status, createdAt])
  @@index([documentId])
}
