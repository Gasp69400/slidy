// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Note projet : la génération IA (CV via /api/cv/generate, présentations via /api/generate) passe par Groq
// (GROQ_API_KEY côté serveur uniquement), pas par cette base PostgreSQL.
// Ce fichier décrit uniquement la persistance (users, présentations, documents, etc.).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Chaîne « Transaction pooler » ou « URI » du projet Supabase (Settings → Database)
  url      = env("SUPABASE_DATABASE_URL")
}

enum PropertySource {
  LEBONCOIN
  SELOGER
  PAP
  PARUVENDU
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum AlertType {
  NEW_MATCH
  PRICE_DROP
  PROPERTY_AVAILABLE
}

enum PlanTier {
  STARTER
  PRO
  TEAM
}

enum DocumentType {
  PRESENTATION
  WHITEBOARD
  DOCUMENT
  NOTES
  VISUAL_PAGE
  MARKETING_PRESENTATION
  CV_COVER
}

enum DocumentStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum BlockType {
  TITLE
  HEADING
  TEXT
  BULLETS
  IMAGE
  CHART
  QUOTE
  CTA
  DIVIDER
}

enum ImageSource {
  AI
  STOCK
  UPLOAD
}

enum GenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  hashedPassword    String?
  stripeCustomerId  String?            @unique
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  clients           Client[]
  accounts          Account[]
  sessions          Session[]
  presentations     Presentation[]
  documents         AiDocument[]
  generationJobs    GenerationJob[]
  mediaAssets       MediaAsset[]

  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  firstName String
  lastName  String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchCriteria   SearchCriteria[]
  matches          Match[]
  alerts           Alert[]

  @@map("clients")
}

model SearchCriteria {
  id            String   @id @default(cuid())
  clientId      String
  budgetMin     Int?
  budgetMax     Int?
  cities        String[] // Array of city names
  surfaceMin    Int?
  surfaceMax    Int?
  roomsMin      Int?
  roomsMax      Int?
  mustHave      String[] // Array of required features (balcony, garden, etc.)
  mustNotHave   String[] // Array of excluded features
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("search_criteria")
}

model Property {
  id          String          @id @default(cuid())
  source      PropertySource
  url         String          @unique
  title       String
  price       Int
  city        String
  surface     Int?
  rooms       Int?
  description String?
  images      String[]        // Array of image URLs
  rawJson     Json?           // Raw data from scraper for debugging
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  matches Match[]
  alerts  Alert[]

  @@map("properties")
  @@index([city])
  @@index([price])
  @@index([surface])
  @@index([rooms])
  @@index([createdAt])
}

model Match {
  id         String   @id @default(cuid())
  clientId   String
  propertyId String
  score      Float    // Score between 0 and 100
  createdAt  DateTime @default(now())

  // Relations
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clientId, propertyId])
  @@map("matches")
  @@index([score])
  @@index([createdAt])
}

model Alert {
  id        String     @id @default(cuid())
  clientId  String
  propertyId String?
  type      AlertType
  message   String
  sent      Boolean    @default(false)
  sentAt    DateTime?
  createdAt DateTime   @default(now())

  // Relations
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id])

  @@map("alerts")
  @@index([clientId])
  @@index([sent])
  @@index([createdAt])
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Template {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  category      String?
  planTier      PlanTier @default(STARTER)
  colorPrimary  String?
  colorSecondary String?
  colorAccent   String?
  colorBg       String?
  colorText     String?
  fontHeading   String?
  fontBody      String?
  previewImage  String?
  isFeatured    Boolean  @default(false)

  @@map("templates")
}

model Presentation {
  id           String   @id @default(cuid())
  userId       String
  title        String
  topic        String
  audience     String
  presentationType String
  templateSlug String
  slideCount   Int
  slidesJson   String
  fileUrl      String?
  status       String   @default("generating")
  options      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presentations")
  @@index([userId, createdAt])
}

model AiDocument {
  id            String         @id @default(cuid())
  userId        String
  title         String
  topic         String
  type          DocumentType   @default(PRESENTATION)
  audience      String?
  detailLevel   String?
  templateSlug  String?
  designOptions Json?
  status        DocumentStatus @default(DRAFT)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks        DocumentBlock[]
  generationJobs GenerationJob[]

  @@map("ai_documents")
  @@index([userId, type, createdAt])
  @@index([status])
}

model DocumentBlock {
  id          String    @id @default(cuid())
  documentId  String
  blockType   BlockType
  position    Int
  contentJson Json
  styleJson   Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document    AiDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_blocks")
  @@unique([documentId, position])
  @@index([documentId])
}

model MediaAsset {
  id           String      @id @default(cuid())
  userId       String
  source       ImageSource
  title        String?
  altText      String?
  mimeType     String?
  width        Int?
  height       Int?
  storageUrl   String
  thumbnailUrl String?
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("media_assets")
  @@index([userId, source, createdAt])
}

model GenerationJob {
  id            String           @id @default(cuid())
  userId        String
  documentId    String?
  status        GenerationStatus @default(QUEUED)
  prompt        String
  model         String?
  detailLevel   String?
  requestedType DocumentType     @default(PRESENTATION)
  optionsJson   Json?
  resultJson    Json?
  errorMessage  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  document      AiDocument?      @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@map("generation_jobs")
  @@index([userId, status, createdAt])
  @@index([documentId])
}
