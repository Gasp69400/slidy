# Copier vers .env.local : cp .env.example .env.local
#
# — Base de données (Prisma / PostgreSQL Supabase) —
# Indépendant de l’IA : la génération CV & présentations utilise Groq (voir plus bas).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Transaction pooler (Supabase > Project Settings > Database > Connection string > URI)
# Choisir « Transaction pooler », port 6543. Encoder les caractères spéciaux du mot de passe (ex. ! → %21).
# ex. postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Si « Authentication failed » : Supabase > Database > Reset database password, puis mettre à jour ici et sur Vercel.
SUPABASE_DATABASE_URL=
# Optionnel — pour `npm run migrate:supabase` (Session pooler ou Direct, port 5432, recommandé)
# SUPABASE_DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Compte(s) fondateur : accès Ultimate (emails de connexion Supabase, séparés par des virgules)
SLIDY_OWNER_EMAILS=
# Alternative : UUID Supabase auth.users (séparés par des virgules)
SLIDY_OWNER_USER_IDS=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# — Génération IA (Groq, lu uniquement côté serveur par les routes /api/*) —
# Fichier à la racine du projet (à côté de package.json). Redémarrer `next dev` après modification.
# Alias accepté : GROQ_KEY (même valeur). Ne pas utiliser NEXT_PUBLIC_* pour une clé secrète.
GROQ_API_KEY=
# GROQ_KEY=
# Modèle Groq pour CV, lettre de motivation et présentations (prioritaire sur tout hint client).
# Valeurs acceptées : id Groq tel que sur console.groq.com ; guillemets et espaces autour sont tolérés.
# GROQ_MODEL=llama-3.3-70b-versatile

# Optionnel (hors flux CV / présentations Groq actuels)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# Déploiement (Vercel, etc.) : ajouter GROQ_API_KEY dans les variables d’environnement
# du projet — le fichier .env.local n’est pas déployé.
